---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title,
  description = "DearSQL is a fast, native desktop SQL client for SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, and MSSQL. No Electron, no bloat. Free tier available.",
  image = "/sc.webp",
  breadcrumbs = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/icon-hero.webp" />
    <link rel="apple-touch-icon" href="/icon-hero.webp" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="SQL client, database manager, SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, MSSQL, desktop app, native, macOS, Linux, Windows"
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="theme-color"
      content="#faf7f0"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1a1a"
      media="(prefers-color-scheme: dark)"
    />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@dunkbingg" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    {
      breadcrumbs.length > 0 && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            itemListElement: breadcrumbs.map((item, i) => ({
              "@type": "ListItem",
              position: i + 1,
              name: item.name,
              item: new URL(item.url, Astro.site).href,
            })),
          })}
        />
      )
    }

    <slot name="head" />

    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=AW-17863164815"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "AW-17863164815");
    </script>
  </head>
  <body>
    <header class="bg-crust border-b border-surface1">
      <nav
        class="max-w-2xl mx-auto px-4 py-2 flex flex-wrap items-center gap-x-1 gap-y-1 text-sm"
      >
        <a
          href="/"
          class="font-bold text-text no-underline flex items-center gap-2 mr-2"
        >
          <img src="/icon.webp" alt="" width="16" height="16" />
          DearSQL
        </a>
        {
          Astro.url.pathname === "/changelog" ? (
            <>
              [
              <a href="/#features" class="no-underline hover:underline">
                features
              </a>
              | <span class="font-bold text-text">changelog</span>|{" "}
              <a
                href="https://github.com/dunkbing/dearsql/issues/new"
                target="_blank"
                class="no-underline hover:underline"
              >
                report bug
              </a>
              ]
            </>
          ) : (
            <>
              [
              <a href="/#features" class="no-underline hover:underline">
                features
              </a>
              |{" "}
              <a href="/changelog" class="no-underline hover:underline">
                changelog
              </a>
              |{" "}
              <a
                href="https://github.com/dunkbing/dearsql/issues/new"
                target="_blank"
                class="no-underline hover:underline"
              >
                report bug
              </a>
              ]
            </>
          )
        }
      </nav>
    </header>

    <slot />
    <Footer />
  </body>
</html>

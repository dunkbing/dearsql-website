---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "A modern desktop SQL client for SQLite, PostgreSQL, MySQL, and Redis. Native performance with a clean, intuitive interface.",
  image = "/icon.webp",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/icon.webp" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="theme-color"
      content="#faf7f0"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1a1a"
      media="(prefers-color-scheme: dark)"
    />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />
  </head>
  <body>
    <slot />

    <!-- Bug report modal -->
    <div
      id="bug-modal"
      class="fixed inset-0 z-100 items-center justify-center"
      style="display: none"
    >
      <div id="bug-overlay" class="absolute inset-0 bg-black/50"></div>
      <div
        class="relative border border-surface1 bg-base p-6 w-full max-w-md mx-4 text-sm"
      >
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold">&gt; report bug</h2>
          <button id="bug-close" class="text-subtext0 hover:text-text"
            >[close]</button
          >
        </div>
        <form id="bug-form" class="space-y-3">
          <div>
            <label class="block text-subtext0 mb-1">name</label>
            <input
              type="text"
              name="name"
              placeholder="optional"
              class="w-full bg-surface0 border border-surface1 px-3 py-1.5 text-text placeholder:text-overlay0 focus:outline-none focus:border-overlay1"
            />
          </div>
          <div>
            <label class="block text-subtext0 mb-1">email</label>
            <input
              type="email"
              name="email"
              placeholder="optional"
              class="w-full bg-surface0 border border-surface1 px-3 py-1.5 text-text placeholder:text-overlay0 focus:outline-none focus:border-overlay1"
            />
          </div>
          <div>
            <label class="block text-subtext0 mb-1">description *</label>
            <textarea
              name="message"
              required
              rows="4"
              placeholder="what happened?"
              class="w-full bg-surface0 border border-surface1 px-3 py-1.5 text-text placeholder:text-overlay0 focus:outline-none focus:border-overlay1 resize-none"
            ></textarea>
          </div>
          <div>
            <label class="block text-subtext0 mb-1">screenshots</label>
            <label
              id="bug-file-label"
              class="flex items-center gap-2 px-3 py-1.5 border border-dashed border-surface1 text-subtext0 hover:text-text hover:border-overlay0 cursor-pointer"
            >
              <span>[+ attach images]</span>
              <input
                type="file"
                id="bug-file-input"
                accept="image/*"
                multiple
                class="hidden"
              />
            </label>
            <div id="bug-previews" class="flex flex-wrap gap-2 mt-2"></div>
          </div>
          <div class="flex items-center justify-between pt-1">
            <span id="bug-status" class="text-subtext0"></span>
            <div class="flex gap-2">
              <button
                type="button"
                id="bug-cancel"
                class="px-3 py-1 border border-surface1 text-subtext0 hover:text-text hover:bg-surface0"
                >[cancel]</button
              >
              <button
                type="submit"
                class="px-3 py-1 border border-surface1 text-text hover:bg-surface0 font-bold"
                >[send]</button
              >
            </div>
          </div>
        </form>
      </div>
    </div>

    <script>
      import * as Sentry from "@sentry/browser";
      import type { Attachment } from "@sentry/core";

      Sentry.init({
        dsn: import.meta.env.PUBLIC_SENTRY_DSN,
        tunnel: "/api/sentry-tunnel",
      });

      const modal = document.getElementById("bug-modal")!;
      const form = document.getElementById("bug-form") as HTMLFormElement;
      const status = document.getElementById("bug-status")!;
      const fileInput = document.getElementById(
        "bug-file-input",
      ) as HTMLInputElement;
      const previewsContainer = document.getElementById("bug-previews")!;

      let selectedFiles: File[] = [];

      fileInput.addEventListener("change", () => {
        const files = fileInput.files;
        if (!files) return;
        for (const file of files) {
          selectedFiles.push(file);
          addPreview(file, selectedFiles.length - 1);
        }
        fileInput.value = "";
      });

      function addPreview(file: File, index: number) {
        const wrapper = document.createElement("div");
        wrapper.className = "relative inline-block";
        wrapper.dataset.index = String(index);

        const img = document.createElement("img");
        img.className = "h-16 border border-surface1";
        img.src = URL.createObjectURL(file);
        img.title = file.name;

        const removeBtn = document.createElement("button");
        removeBtn.type = "button";
        removeBtn.className =
          "absolute -top-1.5 -right-1.5 bg-base border border-surface1 text-subtext0 hover:text-text px-1 text-xs leading-none";
        removeBtn.textContent = "x";
        removeBtn.addEventListener("click", () => {
          selectedFiles[index] = null!;
          wrapper.remove();
        });

        wrapper.appendChild(img);
        wrapper.appendChild(removeBtn);
        previewsContainer.appendChild(wrapper);
      }

      function clearFiles() {
        selectedFiles = [];
        previewsContainer.innerHTML = "";
        fileInput.value = "";
      }

      function openModal() {
        modal.style.display = "flex";
        form.reset();
        clearFiles();
        status.textContent = "";
      }

      function closeModal() {
        modal.style.display = "none";
      }

      document.querySelectorAll("[data-sentry-feedback]").forEach((el) => {
        el.addEventListener("click", (e) => {
          e.preventDefault();
          openModal();
        });
      });

      document
        .getElementById("bug-close")!
        .addEventListener("click", closeModal);
      document
        .getElementById("bug-cancel")!
        .addEventListener("click", closeModal);
      document
        .getElementById("bug-overlay")!
        .addEventListener("click", closeModal);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal.style.display !== "none") {
          closeModal();
        }
      });

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = new FormData(form);
        const message = (data.get("message") as string)?.trim();
        if (!message) return;

        status.textContent = "sending...";

        try {
          const files = selectedFiles.filter(Boolean);
          let attachments: Attachment[] | undefined;

          if (files.length > 0) {
            attachments = await Promise.all(
              files.map(async (file) => ({
                data: new Uint8Array(await file.arrayBuffer()),
                filename: file.name,
                contentType: file.type,
              })),
            );
          }

          Sentry.captureFeedback(
            {
              name: (data.get("name") as string) || undefined,
              email: (data.get("email") as string) || undefined,
              message,
            },
            { attachments },
          );
          status.textContent = "sent!";
          setTimeout(closeModal, 1000);
        } catch {
          status.textContent = "failed to send";
        }
      });
    </script>
  </body>
</html>

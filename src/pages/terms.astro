---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
  title="Terms of Service — DearSQL"
  description="DearSQL terms of service. License terms, permitted use, and warranty information for the free and Pro tiers."
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Terms of Service", url: "/terms" },
  ]}
>
  <main class="max-w-2xl mx-auto px-4 py-6 text-sm">
    <h1 class="text-xl font-bold mb-1">## Terms of Service</h1>
    <p class="text-subtext0 text-xs mb-6">Last updated: March 2026</p>

    <div class="space-y-6 text-subtext0">
      <section>
        <h2 class="font-bold text-text mb-2">### License</h2>
        <p>
          DearSQL is licensed per individual user. A Pro license grants one
          person the right to use DearSQL on their own devices. You may not
          share, resell, or redistribute a license key.
        </p>
        <p class="mt-2">
          The free tier is available to anyone without a license key and is
          subject to usage limits (3 saved connections, 2 workspaces).
        </p>
      </section>

      <section>
        <h2 class="font-bold text-text mb-2">### Permitted use</h2>
        <ul class="space-y-1 ml-2">
          <li>- Personal and commercial use is permitted</li>
          <li>
            - You may use DearSQL to connect to any database you are authorized
            to access
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-bold text-text mb-2">### Prohibited use</h2>
        <ul class="space-y-1 ml-2">
          <li>
            - Reverse engineering, decompiling, or modifying the application
          </li>
          <li>- Redistributing or reselling the software or license keys</li>
          <li>
            - Using the software to access databases without authorization
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-bold text-text mb-2">### Warranty disclaimer</h2>
        <p>
          DearSQL is provided "as is" without warranty of any kind. We are not
          liable for data loss, damages, or interruptions caused by use of the
          software. Always maintain your own database backups.
        </p>
      </section>

      <section>
        <h2 class="font-bold text-text mb-2">### Changes</h2>
        <p>
          We may update these terms at any time. Continued use of the software
          constitutes acceptance of the current terms.
        </p>
      </section>
    </div>
  </main>
</Layout>

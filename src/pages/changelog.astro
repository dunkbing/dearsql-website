---
import Layout from "../layouts/Layout.astro";
import { releases } from "../data/releases";

const currentYear = new Date().getFullYear();
---

<Layout title="Changelog - DearSQL">
  <main class="max-w-2xl mx-auto px-4 py-6">
    <h1 class="text-xl font-bold mb-1">## Changelog</h1>
    <p class="text-subtext0 text-sm mb-6">What's new in DearSQL.</p>

    <div class="space-y-6">
      {
        releases.map((release, i) => (
          <article class:list={[i > 0 && "border-t border-surface1 pt-6"]}>
            <div class="flex items-baseline gap-3 mb-2">
              <h2 class="font-bold">v{release.version}</h2>
              <span class="text-sm text-subtext0">{release.date}</span>
            </div>
            <ul class="space-y-1 text-sm text-subtext0">
              {release.changes.map((change) => (
                <li>- {change}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-surface1 py-3 px-4 mt-6">
    <div class="max-w-2xl mx-auto flex items-center justify-between text-sm text-subtext0">
      <p>&copy; {currentYear} DearSQL</p>
      <a href="mailto:bing@db99.dev">contact</a>
    </div>
  </footer>
</Layout>

---
import Layout from "../layouts/Layout.astro";

const currentYear = new Date().getFullYear();

const changelog = [
  {
    version: "0.2.0",
    date: "2026-03-02",
    changes: [
      "Added native alert dialog.",
      "Fixed MySQL crash.",
      "Fixed tab flash and improved light theme contrast.",
      "Disabled form fields while connecting.",
    ],
  },
  {
    version: "0.1.12",
    date: "2026-02-27",
    changes: [
      "Added one-click SQL formatting.",
      "Added shortcuts: Ctrl+Enter run, Ctrl+/ comment, Ctrl+F/Ctrl+H find and replace.",
      "Improved autocomplete with type indicators.",
      "Synced editor colors with app theme.",
      "Fixed AI chat input affecting the SQL editor.",
    ],
  },
  {
    version: "0.1.11",
    date: "2026-02-27",
    changes: [
      "Replaced the old input with a custom SQL editor.",
      "Added tree-sitter SQL syntax highlighting.",
      "Added autocomplete for SQL keywords and database objects.",
      "Added line numbers, cursor and selection improvements, keyboard and mouse navigation.",
      "Added undo/redo and full clipboard support.",
    ],
  },
];
---

<Layout title="Changelog - DearSQL">
  <div class="min-h-screen">
    <!-- Header -->
    <header
      class="fixed top-0 left-0 right-0 z-50 bg-base border-b border-surface1"
    >
      <nav
        class="max-w-2xl mx-auto px-4 h-10 flex items-center justify-between text-sm"
      >
        <a
          href="/"
          class="no-underline text-text hover:text-text font-bold flex items-center gap-2"
        >
          <img src="/icon.webp" alt="" width="18" height="18" />
          DearSQL
        </a>
        <div class="flex items-center text-subtext0 gap-1">
          [<a href="/#features">features</a>
          | <span class="text-text font-bold">changelog</span>
          | <a href="/#pricing">pricing</a>]
        </div>
      </nav>
    </header>

    <main class="max-w-2xl mx-auto px-4">
      <section class="pt-24 pb-12">
        <h1 class="text-2xl font-bold mb-2">## Changelog</h1>
        <p class="text-subtext0 text-sm mb-8">What's new in DearSQL.</p>

        <div class="space-y-8">
          {
            changelog.map((release, i) => (
              <article
                class:list={[i > 0 && "border-t border-surface1 pt-8"]}
              >
                <div class="flex items-baseline gap-3 mb-3">
                  <h2 class="font-bold">v{release.version}</h2>
                  <span class="text-sm text-subtext0">{release.date}</span>
                </div>
                <ul class="space-y-1 text-sm">
                  {release.changes.map((change) => (
                    <li class="text-subtext0">- {change}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="py-6 px-4 border-t border-surface1">
      <div
        class="max-w-2xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-subtext0"
      >
        <p>&copy; {currentYear} DearSQL</p>
        <a href="mailto:bing@db99.dev">contact</a>
      </div>
    </footer>
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";

const R2_BASE = "https://pub-29493441e7d647038e2f777e7cac5cce.r2.dev";
const macDmgUrl = `${R2_BASE}/DearSQL-0.1.12.dmg`;

let appImageUrl = `${R2_BASE}/DearSQL-0.1.9-x86_64.AppImage`;
try {
  const res = await fetch(`${R2_BASE}/version.json`);
  if (res.ok) {
    const data = await res.json();
    const url = data?.downloads?.["appimage-x86_64"]?.url;
    if (url) appImageUrl = url;
  }
} catch {}

function formatSize(bytes: number): string {
  const mb = bytes / (1024 * 1024);
  return mb >= 1 ? `${mb.toFixed(0)} MB` : `${(bytes / 1024).toFixed(0)} KB`;
}

async function getFileSize(url: string): Promise<string | null> {
  try {
    const res = await fetch(url, { method: "HEAD" });
    const len = res.headers.get("content-length");
    return len ? formatSize(Number(len)) : null;
  } catch {
    return null;
  }
}

const [macSize, linuxSize] = await Promise.all([
  getFileSize(macDmgUrl),
  getFileSize(appImageUrl),
]);

const features = [
  {
    title: "Hand-crafted querying experience",
    description:
      "Syntax highlighting, autocomplete, and query history. Write SQL with less friction and more confidence.",
  },
  {
    title: "Effortless table editing",
    description:
      "Browse, filter, and edit table data inline. Changes are staged and generate proper SQL before committing.",
  },
  {
    title: "Built for performance",
    description:
      "Native C++ with Metal on macOS and OpenGL on Linux. No Electron, no bloat. Just fast, responsive UI.",
  },
];

const databases = [
  { name: "SQLite", icon: "/icons/sqlite.svg" },
  { name: "Postgres", icon: "/icons/postgresql.svg" },
  { name: "MySQL", icon: "/icons/mysql.svg" },
  { name: "MariaDB", icon: "/icons/mariadb.svg" },
  { name: "Redis", icon: "/icons/redis.svg" },
  { name: "MongoDB", icon: "/icons/mongodb.svg" },
];

const currentYear = new Date().getFullYear();
---

<Layout title="DearSQL - Simple, Powerful Database Manager">
  <div class="min-h-screen">
    <!-- Header -->
    <header
      class="fixed top-0 left-0 right-0 z-50 bg-base border-b border-surface1"
    >
      <nav
        class="max-w-2xl mx-auto px-4 h-10 flex items-center justify-between text-sm"
      >
        <a
          href="/"
          class="no-underline text-text hover:text-text font-bold flex items-center gap-2"
        >
          <img src="/icon.webp" alt="" width="18" height="18" />
          DearSQL
        </a>
        <!-- Desktop nav -->
        <div class="hidden sm:flex items-center text-subtext0 gap-1">
          [<a href="#features">features</a>
          | <a href="/changelog">changelog</a>
          | <a href="#pricing">pricing</a>
          | <a href="https://github.com/dunkbing/dearsql" target="_blank"
            >github</a
          >
          | <a
            href="https://github.com/dunkbing/dearsql/issues/new?labels=bug&title=%5BBug%5D+"
            target="_blank">bugs</a
          >]
        </div>
        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          class="sm:hidden text-subtext0 hover:text-text text-sm font-bold"
        >
          <span id="menu-icon-open">[menu]</span>
          <span id="menu-icon-close" class="hidden">[close]</span>
        </button>
      </nav>
      <!-- Mobile menu -->
      <div
        id="mobile-menu"
        class="sm:hidden hidden border-t border-surface1 bg-base"
      >
        <div class="max-w-2xl mx-auto px-4 py-3 flex flex-col gap-2 text-sm">
          <a href="#features" class="py-1">features</a>
          <a href="/changelog" class="py-1">changelog</a>
          <a href="#pricing" class="py-1">pricing</a>
          <a
            href="https://github.com/dunkbing/dearsql"
            target="_blank"
            class="py-1">github</a
          >
          <a
            href="https://github.com/dunkbing/dearsql/issues/new?labels=bug&title=%5BBug%5D+"
            target="_blank"
            class="py-1">report a bug</a
          >
        </div>
      </div>
    </header>

    <main class="max-w-2xl mx-auto px-4">
      <!-- Hero -->
      <section class="pt-24 pb-12 text-center">
        <p class="text-green text-sm mb-4">
          &gt; status: currently in development
        </p>
        <h1 class="text-2xl sm:text-3xl font-bold mb-4">
          A simple<br />database client
        </h1>
        <p class="text-sm mb-2">
          <span class="line-through text-subtext0">AI-powered</span>
          <span class="text-peach font-bold">ImGui-powered</span>
        </p>
        <p class="text-subtext0 max-w-lg mx-auto mb-4">
          Fast, native, no bloat, no electron, no webview, no java.
        </p>

        <!-- Downloads -->
        <div
          class="border border-surface1 p-4 text-left max-w-sm mx-auto text-sm"
        >
          <p class="font-bold mb-2">&gt; Downloads</p>
          <a href={macDmgUrl} class="block py-0.5">
            * macOS (.dmg){
              macSize && (
                <span class="text-subtext0 no-underline"> [{macSize}]</span>
              )
            }
          </a>
          <a href={appImageUrl} class="block py-0.5">
            * Linux (AppImage){
              linuxSize && (
                <span class="text-subtext0 no-underline"> [{linuxSize}]</span>
              )
            }
          </a>
          <span class="block py-0.5 text-subtext0">* Windows — coming soon</span
          >
        </div>
      </section>

      <!-- Screenshot -->
      <section class="pb-16">
        <div class="flex justify-center gap-2 mb-4 text-sm">
          <button
            id="tab-macos"
            class="tab-btn px-3 py-1 border border-surface1 bg-surface0 text-text font-bold"
            data-tab="macos"
          >
            [macOS]
          </button>
          <button
            id="tab-linux"
            class="tab-btn px-3 py-1 border border-surface1 text-subtext0 hover:text-text"
            data-tab="linux"
          >
            [Linux]
          </button>
        </div>
        <div
          id="screenshot-macos"
          class="screenshot-panel border border-surface1 overflow-hidden"
        >
          <img
            src="/sc.webp"
            alt="DearSQL on macOS"
            width="1400"
            height="913"
            fetchpriority="high"
            class="w-full h-auto"
          />
        </div>
        <div
          id="screenshot-linux"
          class="screenshot-panel hidden border border-surface1 overflow-hidden"
        >
          <img
            src="/sc_gtk.webp"
            alt="DearSQL on Linux"
            width="1400"
            height="783"
            fetchpriority="high"
            class="w-full h-auto"
          />
        </div>
      </section>

      <script>
        document
          .querySelectorAll<HTMLButtonElement>(".tab-btn")
          .forEach((btn) => {
            btn.addEventListener("click", () => {
              const tab = btn.dataset.tab;
              document
                .querySelectorAll<HTMLButtonElement>(".tab-btn")
                .forEach((b) => {
                  b.classList.remove("bg-surface0", "text-text", "font-bold");
                  b.classList.add("text-subtext0");
                });
              btn.classList.remove("text-subtext0");
              btn.classList.add("bg-surface0", "text-text", "font-bold");
              document
                .querySelectorAll(".screenshot-panel")
                .forEach((p) => p.classList.add("hidden"));
              document
                .getElementById(`screenshot-${tab}`)
                ?.classList.remove("hidden");
            });
          });
      </script>

      <script>
        const toggle = document.getElementById("menu-toggle")!;
        const menu = document.getElementById("mobile-menu")!;
        const iconOpen = document.getElementById("menu-icon-open")!;
        const iconClose = document.getElementById("menu-icon-close")!;

        toggle.addEventListener("click", () => {
          menu.classList.toggle("hidden");
          iconOpen.classList.toggle("hidden");
          iconClose.classList.toggle("hidden");
        });

        menu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            menu.classList.add("hidden");
            iconOpen.classList.remove("hidden");
            iconClose.classList.add("hidden");
          });
        });
      </script>

      <!-- Features -->
      <section id="features" class="py-16 border-t border-surface1">
        <h2 class="text-xl font-bold mb-2">## Features</h2>
        <p class="text-subtext0 text-sm mb-8">
          No unnecessary complexity. Just what matters for working with
          databases.
        </p>
        <div class="space-y-6 text-sm">
          {
            features.map((f) => (
              <div>
                <h3 class="font-bold">* {f.title}</h3>
                <p class="text-subtext0 ml-2">{f.description}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Databases -->
      <section id="databases" class="py-16 border-t border-surface1">
        <h2 class="text-xl font-bold mb-2">## Supported Databases</h2>
        <p class="text-subtext0 text-sm mb-8">
          Connect to SQLite, PostgreSQL, MySQL, MariaDB, Redis, and MongoDB from
          a single interface.
        </p>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
          {
            databases.map((db) => (
              <div class="text-center border border-surface1 p-4">
                <img src={db.icon} alt={db.name} class="w-8 h-8 mx-auto mb-2" />
                <span class="text-sm">{db.name}</span>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Pricing -->
      <section id="pricing" class="py-16 border-t border-surface1">
        <h2 class="text-xl font-bold mb-2">## Pricing</h2>
        <p class="text-subtext0 text-sm mb-8">
          One-time purchase. No subscriptions, no recurring fees.
        </p>
        <div class="grid sm:grid-cols-2 gap-4 text-sm">
          <!-- Free -->
          <div class="border border-surface1 p-6">
            <h3 class="font-bold mb-1">Free</h3>
            <p class="text-subtext0 mb-4">For getting started</p>
            <p class="text-2xl font-bold mb-4">$0</p>
            <ul class="text-subtext0 space-y-1">
              <li>[+] SQLite support</li>
              <li>[+] Table editor</li>
              <li>[+] Query editor</li>
            </ul>
          </div>
          <!-- License -->
          <div class="border-2 border-peach p-6">
            <h3 class="font-bold mb-1">License</h3>
            <p class="text-subtext0 mb-4">For professionals</p>
            <p class="text-2xl font-bold mb-4">
              $30 <span class="text-sm text-subtext0 font-normal">USD</span>
            </p>
            <ul class="text-subtext0 space-y-1">
              <li>[+] All databases</li>
              <li>[+] Up to 3 devices</li>
              <li>[+] All future updates</li>
              <li>[+] ER diagrams</li>
              <li>[+] Support development</li>
            </ul>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="py-6 px-4 border-t border-surface1">
      <div
        class="max-w-2xl mx-auto flex items-center justify-between text-sm text-subtext0"
      >
        <p>&copy; {currentYear} DearSQL</p>
        <div class="flex gap-3">
          [<a href="https://www.threads.net/@dunkbingg" target="_blank"
            >threads</a
          >] [<a href="https://x.com/dunkbingg" target="_blank">x</a>] [<a
            href="https://github.com/dunkbing/dearsql"
            target="_blank">github</a
          >] [<a href="mailto:bing@db99.dev">email</a>]
        </div>
      </div>
    </footer>
  </div>
</Layout>

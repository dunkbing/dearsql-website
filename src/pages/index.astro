---
import { R2_BASE } from "../data/releases";
import Layout from "../layouts/Layout.astro";

const macDmgUrl = `${R2_BASE}/DearSQL-0.3.0.dmg`;
const winMsiUrl = `${R2_BASE}/DearSQL-0.3.0-x64.msi`;

let appImageUrl = `${R2_BASE}/DearSQL-0.2.3-x86_64.AppImage`;
try {
  const res = await fetch(`${R2_BASE}/version.json`);
  if (res.ok) {
    const data = await res.json();
    const url = data?.downloads?.["appimage-x86_64"]?.url;
    if (url) appImageUrl = url;
  }
} catch {}

function formatSize(bytes: number): string {
  const mb = bytes / (1024 * 1024);
  return mb >= 1 ? `${mb.toFixed(0)} MB` : `${(bytes / 1024).toFixed(0)} KB`;
}

async function getFileSize(url: string): Promise<string | null> {
  try {
    const res = await fetch(url, { method: "HEAD" });
    const len = res.headers.get("content-length");
    return len ? formatSize(Number(len)) : null;
  } catch {
    return null;
  }
}

const [macSize, linuxSize, winSize] = await Promise.all([
  getFileSize(macDmgUrl),
  getFileSize(appImageUrl),
  getFileSize(winMsiUrl),
]);

const features = [
  "Syntax highlighting, autocomplete, and query history.",
  "Browse and edit table data inline. Changes generate proper SQL before committing.",
  "SQLite, PostgreSQL, MySQL, MongoDB, Redis, and Oracle in one app.",
  "Saved connections with encrypted credentials.",
  "Schema browser — tables, views, indexes, and more.",
  "Native C++ with Metal on macOS, OpenGL on Linux, and DirectX on Windows.",
];

const currentYear = new Date().getFullYear();
---

<Layout title="DearSQL - Simple, Powerful Database Manager">
  <main class="max-w-2xl mx-auto px-4 py-6">
    <!-- Hero -->
    <section class="pb-6">
      <p class="text-green text-sm mb-3">
        &gt; status: currently in development
      </p>
      <h1 class="text-xl font-bold mb-2">A simple database client.</h1>
      <p class="text-sm mb-1">
        <span class="line-through text-subtext0">AI-powered</span>
        <span class="text-peach font-bold"> ImGui-powered.</span>
      </p>
      <p class="text-subtext0 text-sm mb-5">
        Fast, native, no bloat, no electron, no webview, no java.
      </p>

      <!-- Downloads -->
      <div class="text-sm">
        <p class="font-bold mb-1">&gt; Downloads</p>
        <a href={macDmgUrl} class="block py-0.5">
          * macOS (.dmg){
            macSize && (
              <span class="text-subtext0 no-underline"> [{macSize}]</span>
            )
          }
        </a>
        <div class="flex items-center gap-2 py-0.5 flex-wrap">
          <a href={appImageUrl}>
            * Linux (AppImage){
              linuxSize && (
                <span class="text-subtext0 no-underline"> [{linuxSize}]</span>
              )
            }
          </a>
          <span class="text-subtext0">or:</span>
          <div
            class="flex items-center gap-1.5 bg-surface0 border border-surface1 px-2 py-0.5 rounded text-xs font-mono"
          >
            <span>
              <span class="text-blue">curl</span>
              <span class="text-subtext0"> -fsSL </span>
              <span class="text-green">https://dearsql.dev/install.sh</span>
              <span class="text-subtext0"> | </span>
              <span class="text-blue">sh</span>
            </span>
            <button
              id="copy-install-cmd"
              title="Copy"
              style="background:none;border:none;padding:0;cursor:pointer;display:flex;align-items:center;"
            >
              <span
                id="copy-icon"
                style="display:inline-block;width:13px;height:13px;background-color:currentColor;-webkit-mask:url('/icons/copy.svg') no-repeat center;mask:url('/icons/copy.svg') no-repeat center;-webkit-mask-size:contain;mask-size:contain;"
              ></span>
              <span
                id="check-icon"
                style="display:none;width:13px;height:13px;background-color:var(--green);-webkit-mask:url('/icons/check.svg') no-repeat center;mask:url('/icons/check.svg') no-repeat center;-webkit-mask-size:contain;mask-size:contain;"
              ></span>
            </button>
          </div>
        </div>
      </div>
      <script>
        const btn = document.getElementById("copy-install-cmd");
        const copyIcon = document.getElementById("copy-icon");
        const checkIcon = document.getElementById("check-icon");
        btn?.addEventListener("click", () => {
          navigator.clipboard.writeText(
            "curl -fsSL https://dearsql.dev/install.sh | sh",
          );
          copyIcon!.style.display = "none";
          checkIcon!.style.display = "inline-block";
          setTimeout(() => {
            copyIcon!.style.display = "inline-block";
            checkIcon!.style.display = "none";
          }, 1500);
        });
      </script>
      <a href={winMsiUrl} class="block py-0.5">
        * Windows (.msi){
          winSize && (
            <span class="text-subtext0 no-underline"> [{winSize}]</span>
          )
        }
      </a>
    </section>

    <!-- Screenshot -->
    <section class="pb-6 border-t border-surface1 pt-4">
      <div class="flex gap-2 mb-3 text-sm text-subtext0">
        <button
          id="tab-macos"
          class="tab-btn"
          data-tab="macos"
          style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;font-size:inherit;font-weight:bold;text-decoration:underline;color:var(--text);"
          >macOS</button
        >
        <span>|</span>
        <button
          id="tab-linux"
          class="tab-btn"
          data-tab="linux"
          style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;font-size:inherit;color:var(--subtext0);"
          >Linux</button
        >
      </div>
      <div
        id="screenshot-macos"
        class="screenshot-panel border border-surface1 overflow-hidden"
      >
        <img
          src="/sc.webp"
          alt="DearSQL on macOS"
          width="1400"
          height="913"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
      <div
        id="screenshot-linux"
        class="screenshot-panel hidden border border-surface1 overflow-hidden"
      >
        <img
          src="/sc_gtk.webp"
          alt="DearSQL on Linux"
          width="1400"
          height="783"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
    </section>

    <script>
      document
        .querySelectorAll<HTMLButtonElement>(".tab-btn")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            const tab = btn.dataset.tab;
            document
              .querySelectorAll<HTMLButtonElement>(".tab-btn")
              .forEach((b) => {
                b.style.color = "var(--subtext0)";
                b.style.fontWeight = "";
                b.style.textDecoration = "none";
              });
            btn.style.color = "var(--text)";
            btn.style.fontWeight = "bold";
            btn.style.textDecoration = "underline";
            document
              .querySelectorAll(".screenshot-panel")
              .forEach((p) => p.classList.add("hidden"));
            document
              .getElementById(`screenshot-${tab}`)
              ?.classList.remove("hidden");
          });
        });
    </script>

    <!-- Features -->
    <section id="features" class="pb-6 border-t border-surface1 pt-4">
      <h2 class="font-bold mb-2">## Features</h2>
      <ul class="text-sm text-subtext0 space-y-1">
        {features.map((f) => <li>- {f}</li>)}
      </ul>
    </section>

    <!-- Databases -->
    <section id="databases" class="pb-6 border-t border-surface1 pt-4">
      <h2 class="font-bold mb-2">## Supported Databases</h2>
      <p class="text-sm text-subtext0">
        SQLite, PostgreSQL, MySQL, MariaDB, Redis, MongoDB, Oracle.
      </p>
    </section>
  </main>
</Layout>

<!-- Footer -->
<footer class="border-t border-surface1 py-3 px-4">
  <div
    class="max-w-2xl mx-auto flex items-center justify-between text-sm text-subtext0"
  >
    <p>&copy; {currentYear} DearSQL</p>
    <div class="flex gap-3">
      [<a href="https://www.threads.net/@dunkbingg" target="_blank">threads</a>]
      [<a href="https://x.com/dunkbingg" target="_blank">x</a>] [<a
        href="mailto:bing@db99.dev">email</a
      >]
    </div>
  </div>
</footer>

---
import { appImageUrl, dmgUrl, msiUrl, releases } from "../data/releases";
import Layout from "../layouts/Layout.astro";

const latestRelease = releases[0];
const macDmgUrl = dmgUrl(latestRelease.version);
const linuxAppImageUrl = appImageUrl(latestRelease.version);
const winMsiUrl = msiUrl(latestRelease.version);

function formatSize(bytes: number): string {
  const mb = bytes / (1024 * 1024);
  return mb >= 1 ? `${mb.toFixed(0)} MB` : `${(bytes / 1024).toFixed(0)} KB`;
}

async function getFileSize(url: string): Promise<string | null> {
  try {
    const res = await fetch(url, { method: "HEAD" });
    const len = res.headers.get("content-length");
    return len ? formatSize(Number(len)) : null;
  } catch {
    return null;
  }
}

const [macSize, linuxSize, winSize] = await Promise.all([
  getFileSize(macDmgUrl),
  getFileSize(linuxAppImageUrl),
  getFileSize(winMsiUrl),
]);

const features = [
  "Syntax highlighting, autocomplete, and query history.",
  "Browse and edit table data inline. Changes generate proper SQL before committing.",
  "SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, and MSSQL in one app.",
  "Saved connections with encrypted credentials.",
  "Schema browser — tables, views, indexes, and more.",
  "Native C++ with Metal on macOS, OpenGL on Linux, and DirectX on Windows.",
];

const currentYear = new Date().getFullYear();
---

<Layout
  title="DearSQL — Native Desktop SQL Client for macOS, Linux & Windows"
  description="DearSQL is a fast, native desktop SQL client. Connect to SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, and MSSQL. No Electron, no bloat. Free tier available."
>
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "DearSQL",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "macOS, Linux, Windows",
      offers: [
        {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD",
          name: "Free",
        },
        {
          "@type": "Offer",
          price: "35",
          priceCurrency: "USD",
          name: "Pro",
        },
      ],
      description:
        "Fast, native desktop SQL client for SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, and MSSQL. Built with C++ and ImGui.",
      url: "https://dearsql.dev",
      screenshot: "https://dearsql.dev/sc.webp",
    })}
  />
  <script
    is:inline
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "What databases does DearSQL support?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "DearSQL supports SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, and MSSQL — all in one native desktop app.",
          },
        },
        {
          "@type": "Question",
          name: "Is DearSQL free?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. The free tier includes all database types and core features with up to 3 saved connections and 2 workspaces. The Pro license ($35 one-time) unlocks unlimited connections and workspaces.",
          },
        },
        {
          "@type": "Question",
          name: "What platforms does DearSQL run on?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "DearSQL runs natively on macOS (Metal), Linux (OpenGL), and Windows (DirectX). It is built with C++ and ImGui — no Electron or JVM.",
          },
        },
        {
          "@type": "Question",
          name: "Does DearSQL support SSH tunneling?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. DearSQL supports SSH tunneling for all server-type databases, allowing you to connect through a bastion/jump host with password or private key authentication.",
          },
        },
        {
          "@type": "Question",
          name: "Does DearSQL support TLS/SSL connections?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Yes. All server-type backends support TLS/SSL encryption with configurable modes including disable, prefer, require, verify-ca, and verify-full depending on the database.",
          },
        },
      ],
    })}
  />
  <main class="max-w-2xl mx-auto px-4 py-6">
    <!-- Hero -->
    <section class="pb-6">
      <p class="text-subtext0 text-xs mb-2">
        <a
          href="https://github.com/dunkbing/dearsql"
          target="_blank"
          class="no-underline hover:underline">open source</a
        >
      </p>
      <h1 class="text-xl font-bold mb-2">
        Native SQL client for macOS, Linux & Windows.
      </h1>
      <p class="text-sm mb-1">
        <span class="line-through text-subtext0">AI-powered</span>
        <span class="text-peach font-bold"> ImGui-powered.</span>
      </p>
      <p class="text-subtext0 text-sm mb-2">
        No Electron. No JVM. No bloat. Built with C++.
      </p>
      <div class="flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-subtext0 mb-5">
        <span
          >* SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, MSSQL</span
        >
        <span>* SSH tunneling & TLS</span>
        <span>* AI assistant</span>
      </div>

      <!-- Downloads -->
      <div class="border border-surface1 bg-surface0 text-sm mt-4">
        <p class="font-bold text-green px-3 py-2 border-b border-surface1">
          &gt; Downloads
        </p>
        <a
          href={macDmgUrl}
          class="flex items-center px-3 py-2 border-b border-surface1 hover:bg-surface1 no-underline gap-2"
        >
          <span
            ><span class="text-subtext0">* </span>macOS <span
              class="text-subtext0">(.dmg)</span
            ></span
          >
          {macSize && <span class="text-subtext0 text-xs">[{macSize}]</span>}
        </a>
        <div class="border-b border-surface1">
          <a
            href={linuxAppImageUrl}
            class="flex items-center px-3 pt-2 pb-1 hover:bg-surface1 no-underline gap-2"
          >
            <span
              ><span class="text-subtext0">* </span>Linux <span
                class="text-subtext0">(AppImage)</span
              ></span
            >
            {
              linuxSize && (
                <span class="text-subtext0 text-xs">[{linuxSize}]</span>
              )
            }
          </a>
          <div class="flex items-center gap-2 px-3 pb-2">
            <span class="text-subtext0 text-xs">or:</span>
            <div
              class="flex items-center gap-1.5 bg-crust border border-surface1 px-2 py-0.5 text-xs font-mono"
            >
              <span>
                <span class="text-blue">curl</span>
                <span class="text-subtext0"> -fsSL </span>
                <span class="text-green">https://dearsql.dev/install.sh</span>
                <span class="text-subtext0"> | </span>
                <span class="text-blue">sh</span>
              </span>
              <button
                id="copy-install-cmd"
                title="Copy"
                style="background:none;border:none;padding:0;cursor:pointer;display:flex;align-items:center;"
              >
                <span
                  id="copy-icon"
                  style="display:inline-block;width:13px;height:13px;background-color:currentColor;-webkit-mask:url('/icons/copy.svg') no-repeat center;mask:url('/icons/copy.svg') no-repeat center;-webkit-mask-size:contain;mask-size:contain;"
                ></span>
                <span
                  id="check-icon"
                  style="display:none;width:13px;height:13px;background-color:var(--green);-webkit-mask:url('/icons/check.svg') no-repeat center;mask:url('/icons/check.svg') no-repeat center;-webkit-mask-size:contain;mask-size:contain;"
                ></span>
              </button>
            </div>
          </div>
        </div>
        <a
          href={winMsiUrl}
          class="flex items-center px-3 py-2 hover:bg-surface1 no-underline gap-2"
        >
          <span
            ><span class="text-subtext0">* </span>Windows <span
              class="text-subtext0">(.msi)</span
            ></span
          >
          {winSize && <span class="text-subtext0 text-xs">[{winSize}]</span>}
        </a>
      </div>
      <script>
        const btn = document.getElementById("copy-install-cmd");
        const copyIcon = document.getElementById("copy-icon");
        const checkIcon = document.getElementById("check-icon");
        btn?.addEventListener("click", (e) => {
          e.stopPropagation();
          const showCheck = () => {
            copyIcon!.style.display = "none";
            checkIcon!.style.display = "inline-block";
            setTimeout(() => {
              copyIcon!.style.display = "inline-block";
              checkIcon!.style.display = "none";
            }, 1500);
          };
          navigator.clipboard
            .writeText("curl -fsSL https://dearsql.dev/install.sh | sh")
            .then(showCheck)
            .catch(showCheck);
        });
      </script>
    </section>

    <!-- Screenshot -->
    <section class="pb-6 border-t border-surface1 pt-4">
      <div class="flex gap-2 mb-3 text-sm text-subtext0">
        <button
          id="tab-macos"
          class="tab-btn"
          data-tab="macos"
          style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;font-size:inherit;font-weight:bold;text-decoration:underline;color:var(--text);"
          >macOS</button
        >
        <span>|</span>
        <button
          id="tab-linux"
          class="tab-btn"
          data-tab="linux"
          style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;font-size:inherit;color:var(--subtext0);"
          >Linux</button
        >
        <span>|</span>
        <button
          id="tab-windows"
          class="tab-btn"
          data-tab="windows"
          style="background:none;border:none;padding:0;cursor:pointer;font-family:inherit;font-size:inherit;color:var(--subtext0);"
          >Windows</button
        >
      </div>
      <div
        id="screenshot-macos"
        class="screenshot-panel border border-surface1 overflow-hidden"
      >
        <img
          src="/sc.webp"
          alt="DearSQL on macOS"
          width="1400"
          height="913"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
      <div
        id="screenshot-linux"
        class="screenshot-panel hidden border border-surface1 overflow-hidden"
      >
        <img
          src="/sc_gtk.webp"
          alt="DearSQL on Linux"
          width="1400"
          height="783"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
      <div
        id="screenshot-windows"
        class="screenshot-panel hidden border border-surface1 overflow-hidden"
      >
        <img
          src="/sc_win.webp"
          alt="DearSQL on Windows"
          width="1400"
          height="913"
          fetchpriority="high"
          class="w-full h-auto"
        />
      </div>
    </section>

    <script>
      document
        .querySelectorAll<HTMLButtonElement>(".tab-btn")
        .forEach((btn) => {
          btn.addEventListener("click", () => {
            const tab = btn.dataset.tab;
            document
              .querySelectorAll<HTMLButtonElement>(".tab-btn")
              .forEach((b) => {
                b.style.color = "var(--subtext0)";
                b.style.fontWeight = "";
                b.style.textDecoration = "none";
              });
            btn.style.color = "var(--text)";
            btn.style.fontWeight = "bold";
            btn.style.textDecoration = "underline";
            document
              .querySelectorAll(".screenshot-panel")
              .forEach((p) => p.classList.add("hidden"));
            document
              .getElementById(`screenshot-${tab}`)
              ?.classList.remove("hidden");
          });
        });
    </script>

    <!-- Features -->
    <section id="features" class="pb-6 border-t border-surface1 pt-4">
      <h2 class="font-bold mb-2">## Features</h2>
      <ul class="text-sm text-subtext0 space-y-1">
        {features.map((f) => <li>- {f}</li>)}
      </ul>
    </section>

    <!-- Databases -->
    <section id="databases" class="pb-6 border-t border-surface1 pt-4">
      <h2 class="font-bold mb-2">## Supported Databases</h2>
      <p class="text-sm text-subtext0">
        SQLite, PostgreSQL, MySQL, MariaDB, MongoDB, Redis, Oracle, MSSQL.
      </p>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="pb-6 border-t border-surface1 pt-4">
      <h2 class="font-bold mb-4">## Pricing</h2>
      <div class="grid grid-cols-2 gap-3 text-sm">
        <!-- Free -->
        <div class="border border-surface1 bg-surface0">
          <div class="px-3 py-2 border-b border-surface1">
            <span class="font-bold">Free</span>
            <span class="text-subtext0 text-xs ml-2">forever</span>
          </div>
          <div class="px-3 py-2 border-b border-surface1">
            <span class="text-2xl font-bold">$0</span>
          </div>
          <ul class="px-3 py-2 space-y-1 text-subtext0">
            <li>- 10 saved connections</li>
            <li>- 2 workspaces</li>
            <li>- all database types</li>
            <li>- all core features</li>
          </ul>
        </div>

        <!-- Pro -->
        <div class="border border-green bg-surface0">
          <div class="px-3 py-2 border-b border-green">
            <span class="font-bold text-green">Pro</span>
            <span class="text-subtext0 text-xs ml-2">one-time</span>
          </div>
          <div class="px-3 py-2 border-b border-green">
            <span class="text-2xl font-bold">$35</span>
          </div>
          <ul class="px-3 py-2 space-y-1 text-subtext0">
            <li>- unlimited connections</li>
            <li>- unlimited workspaces</li>
            <li>- all database types</li>
            <li>- all current & future features</li>
          </ul>
          <div class="px-3 pb-3">
            <a
              id="buy-now-link"
              href="https://buy.polar.sh/polar_cl_IpYdAWiNljfzsXgatypm2mg40Mm2c4hB0DcVX1L9P6p"
              class="block text-center bg-green text-crust font-bold px-3 py-1.5 no-underline hover:opacity-90 text-xs mt-2"
            >
              buy now &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

#!/usr/bin/env bash
#
# XMRig 6.26.0 setup script
# - Downloads and extracts the static linux x64 prebuilt binary
# - Writes config.json (edit WALLET below before running)
# - Installs systemd service + start/stop timers
# - Schedule (Asia/Ho_Chi_Minh / GMT+7):
#     Mon-Fri: mine 20:00 -> 08:00 next day
#     Weekend: mine continuously (Fri 20:00 -> Mon 08:00)
#
# Thread selection:
#   MODE=full   -> use all physical cores (default; best for scheduled/idle mining)
#   MODE=half   -> use 50% of physical cores (min 1)
#   THREADS=N   -> use exactly N threads (overrides MODE)
#
# Examples:
#   ./setup-xmrig.sh                  # full physical cores
#   MODE=half ./setup-xmrig.sh        # half of physical cores
#   THREADS=3 ./setup-xmrig.sh        # exactly 3 threads
#

set -euo pipefail

# ====== EDIT THESE ============================================================
WALLET="45vpKWFmvT8LCCAwHv73Nn5UV7549FjBZ54g8k5iUfZZcpsA2UrzC5TAa5tAgTpufYCrVzKtBndk97nWXrikiRhoTCRLnnB"
WORKER_NAME="worker1"

# Pool: using TLS port (9000). For non-TLS use 3333 + tls=false.
POOL_URL="pool.supportxmr.com:9000"
POOL_TLS="true"

# Thread mode: full | half  (or set THREADS=N for explicit count)
MODE="${MODE:-full}"
THREADS="${THREADS:-}"

# Where to install xmrig
INSTALL_DIR="${INSTALL_DIR:-$HOME/xmrig}"

# XMRig version + download
XMRIG_VERSION="6.26.0"
XMRIG_TARBALL="xmrig-${XMRIG_VERSION}-linux-static-x64.tar.gz"
XMRIG_URL="https://github.com/xmrig/xmrig/releases/download/v${XMRIG_VERSION}/${XMRIG_TARBALL}"

# Schedule timezone
TZ_NAME="Asia/Ho_Chi_Minh"
# ==============================================================================

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; }

# ---- sanity checks -----------------------------------------------------------
if [[ "$WALLET" == "YOUR_WALLET_ADDRESS" || -z "$WALLET" ]]; then
    err "Edit the WALLET variable at the top of this script first."
    exit 1
fi

if ! command -v sudo >/dev/null 2>&1; then
    err "sudo is required."
    exit 1
fi

USER_NAME="$(id -un)"

# ---- determine thread count --------------------------------------------------
CORES_PER_SOCKET=$(lscpu | awk -F: '/^Core\(s\) per socket/ {gsub(/ /,"",$2); print $2}')
SOCKETS=$(lscpu | awk -F: '/^Socket\(s\)/ {gsub(/ /,"",$2); print $2}')
THREADS_PER_CORE=$(lscpu | awk -F: '/^Thread\(s\) per core/ {gsub(/ /,"",$2); print $2}')
PHYSICAL_CORES=$((CORES_PER_SOCKET * SOCKETS))
LOGICAL_CPUS=$((PHYSICAL_CORES * THREADS_PER_CORE))

log "CPU detected:"
echo "      physical cores : $PHYSICAL_CORES"
echo "      threads/core   : $THREADS_PER_CORE  (hyperthreading: $([ "$THREADS_PER_CORE" -gt 1 ] && echo on || echo off))"
echo "      logical CPUs   : $LOGICAL_CPUS"

if [[ -n "$THREADS" ]]; then
    log "Using explicit THREADS=$THREADS"
elif [[ "$MODE" == "half" ]]; then
    THREADS=$(( PHYSICAL_CORES / 2 ))
    [[ "$THREADS" -lt 1 ]] && THREADS=1
    log "MODE=half -> using $THREADS thread(s)"
elif [[ "$MODE" == "full" ]]; then
    THREADS=$PHYSICAL_CORES
    log "MODE=full -> using $THREADS thread(s) (all physical cores)"
else
    err "Unknown MODE=$MODE  (use 'full' or 'half', or set THREADS=N)"
    exit 1
fi

# Build the rx array: [0, 1, 2, ..., THREADS-1]
RX_ARRAY="[$(seq -s, 0 $((THREADS - 1)))]"

# ---- download + extract ------------------------------------------------------
log "Installing to: $INSTALL_DIR"
mkdir -p "$INSTALL_DIR"
cd "$INSTALL_DIR"

if [[ ! -f "$XMRIG_TARBALL" ]]; then
    log "Downloading XMRig ${XMRIG_VERSION}..."
    wget -q --show-progress "$XMRIG_URL"
else
    log "Tarball already present, skipping download."
fi

log "Extracting..."
tar -xf "$XMRIG_TARBALL"

EXTRACTED_DIR="$INSTALL_DIR/xmrig-${XMRIG_VERSION}"
if [[ -d "$EXTRACTED_DIR" ]]; then
    cp -f "$EXTRACTED_DIR/xmrig" "$INSTALL_DIR/xmrig"
    chmod +x "$INSTALL_DIR/xmrig"
fi

# ---- write config.json -------------------------------------------------------
log "Writing config.json (threads=$THREADS, rx=$RX_ARRAY, pool=$POOL_URL tls=$POOL_TLS)..."
cat > "$INSTALL_DIR/config.json" <<EOF
{
    "api": { "id": null, "worker-id": null },
    "http": {
        "enabled": false,
        "host": "127.0.0.1",
        "port": 0,
        "access-token": null,
        "restricted": true
    },
    "autosave": true,
    "background": false,
    "colors": true,
    "title": true,
    "randomx": {
        "init": -1,
        "init-avx2": -1,
        "mode": "auto",
        "1gb-pages": false,
        "rdmsr": true,
        "wrmsr": true,
        "cache_qos": false,
        "numa": true,
        "scratchpad_prefetch_mode": 1
    },
    "cpu": {
        "enabled": true,
        "huge-pages": true,
        "huge-pages-jit": false,
        "hw-aes": null,
        "priority": 1,
        "memory-pool": false,
        "yield": true,
        "asm": true,
        "argon2-impl": null,
        "rx": ${RX_ARRAY}
    },
    "log-file": null,
    "donate-level": 1,
    "donate-over-proxy": 1,
    "pools": [
        {
            "algo": null,
            "coin": null,
            "url": "${POOL_URL}",
            "user": "${WALLET}",
            "pass": "${WORKER_NAME}",
            "rig-id": null,
            "nicehash": false,
            "keepalive": true,
            "enabled": true,
            "tls": ${POOL_TLS},
            "sni": false,
            "tls-fingerprint": null,
            "daemon": false,
            "socks5": null,
            "self-select": null,
            "submit-to-origin": false
        }
    ],
    "retries": 5,
    "retry-pause": 5,
    "print-time": 60,
    "dmi": true,
    "syslog": false,
    "tls": {
        "enabled": false,
        "protocols": null,
        "cert": null,
        "cert_key": null,
        "ciphers": null,
        "ciphersuites": null,
        "dhparam": null
    },
    "dns": { "ip_version": 0, "ttl": 30 },
    "user-agent": null,
    "verbose": 0,
    "watch": true,
    "pause-on-battery": false,
    "pause-on-active": false
}
EOF

# ---- enable huge pages -------------------------------------------------------
log "Enabling huge pages (1280)..."
sudo sysctl -w vm.nr_hugepages=1280 >/dev/null
if ! grep -q "^vm.nr_hugepages" /etc/sysctl.conf 2>/dev/null; then
    echo "vm.nr_hugepages=1280" | sudo tee -a /etc/sysctl.conf >/dev/null
    log "Added vm.nr_hugepages=1280 to /etc/sysctl.conf (persists across reboots)"
fi

# ---- systemd: main xmrig service --------------------------------------------
log "Creating systemd units..."

sudo tee /etc/systemd/system/xmrig.service >/dev/null <<EOF
[Unit]
Description=XMRig Monero Miner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=${USER_NAME}
WorkingDirectory=${INSTALL_DIR}
ExecStart=${INSTALL_DIR}/xmrig
Restart=on-failure
RestartSec=10
Nice=10
CapabilityBoundingSet=CAP_SYS_NICE CAP_IPC_LOCK
AmbientCapabilities=CAP_SYS_NICE CAP_IPC_LOCK

[Install]
WantedBy=multi-user.target
EOF

# ---- systemd: start trigger --------------------------------------------------
sudo tee /etc/systemd/system/xmrig-start.service >/dev/null <<'EOF'
[Unit]
Description=Start XMRig (triggered by timer)

[Service]
Type=oneshot
ExecStart=/bin/systemctl start xmrig.service
EOF

sudo tee /etc/systemd/system/xmrig-start.timer >/dev/null <<EOF
[Unit]
Description=Start XMRig on schedule (Mon-Fri 20:00, Sat 00:00)

[Timer]
OnCalendar=Mon..Fri 20:00 ${TZ_NAME}
OnCalendar=Sat 00:00 ${TZ_NAME}
Persistent=false
Unit=xmrig-start.service

[Install]
WantedBy=timers.target
EOF

# ---- systemd: stop trigger ---------------------------------------------------
sudo tee /etc/systemd/system/xmrig-stop.service >/dev/null <<'EOF'
[Unit]
Description=Stop XMRig (triggered by timer)

[Service]
Type=oneshot
ExecStart=/bin/systemctl stop xmrig.service
EOF

sudo tee /etc/systemd/system/xmrig-stop.timer >/dev/null <<EOF
[Unit]
Description=Stop XMRig on schedule (Mon-Fri 08:00)

[Timer]
OnCalendar=Mon..Fri 08:00 ${TZ_NAME}
Persistent=false
Unit=xmrig-stop.service

[Install]
WantedBy=timers.target
EOF

# ---- enable timers -----------------------------------------------------------
log "Reloading systemd and enabling timers..."
sudo systemctl daemon-reload
sudo systemctl enable --now xmrig-start.timer
sudo systemctl enable --now xmrig-stop.timer

sudo systemctl disable xmrig.service 2>/dev/null || true

# Restart xmrig if it's currently running so it picks up the new config
if sudo systemctl is-active --quiet xmrig.service; then
    log "xmrig is running -> restarting to apply new config"
    sudo systemctl restart xmrig.service
fi

# ---- summary -----------------------------------------------------------------
echo
log "Setup complete."
echo
echo "Install dir : $INSTALL_DIR"
echo "Threads     : $THREADS  (rx = $RX_ARRAY)"
echo "Wallet      : ${WALLET:0:12}...${WALLET: -8}"
echo "Pool        : $POOL_URL  (tls=$POOL_TLS)"
echo "Schedule    : Mon-Fri 20:00 -> 08:00, all weekend ($TZ_NAME)"
echo
echo "Useful commands:"
echo "  systemctl list-timers --all | grep xmrig    # see next scheduled runs"
echo "  systemctl status xmrig                      # current status"
echo "  journalctl -u xmrig -f                      # live log"
echo "  sudo systemctl start xmrig                  # start now (manual test)"
echo "  sudo systemctl stop xmrig                   # stop now (manual)"
echo
warn "If you change MODE/THREADS later, just re-run this script -- it'll rewrite"
warn "the config and restart xmrig automatically if it's already running."
